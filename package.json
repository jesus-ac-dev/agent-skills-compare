{
  "name": "agentic-repo-explorer",
  "version": "1.0.0",
  "description": "Pipeline inteligente para descobrir, extrair e analisar agentes, skills e workflows em repositórios GitHub e websites.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "pipeline:dev": "node --watch src/index.js",
    "dev": "next dev",
    "build": "next build",
    "web:start": "next start",
    "crawl": "node src/crawler/crawlPage.js",
    "search:github": "node src/github/searchRepos.js",
    "fetch:files": "node src/github/fetchFiles.js",
    "analyze": "node src/analysis/runAnalysis.js",
    "rank": "node src/analysis/ranking.js",
    "agent": "node Gemini/runtime/agent-loop.js",
    "verify": "npm run format && npm run test && npm run lint",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "lint": "next lint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:start": "supabase start",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --local > src/lib/supabase/types.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@google/generative-ai": "^0.21.0",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.7.2",
    "cheerio": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "groq-sdk": "^1.1.2",
    "lucide-react": "^1.14.0",
    "next": "15.5.18",
    "node-fetch": "^3.3.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "shadcn": "^4.7.0",
    "simple-git": "^3.27.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "15.5.18",
    "globals": "^15.9.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "neostandard": "^0.12.0",
    "prettier": "^3.2.5",
    "supabase": "^2.91.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^1.6.0"
  },
  "lint-staged": {
    "*.{js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
